{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EnergyLossPlus",
  "version": "0.1.1",
  "identifier": "com.energylossplus.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EnergyLossPlus",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "energylossplus"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
